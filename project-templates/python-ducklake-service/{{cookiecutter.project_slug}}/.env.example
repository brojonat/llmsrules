# --- Required ---
export {{cookiecutter.package_name_upper}}_JWT_SECRET="change-me-in-production"
export {{cookiecutter.package_name_upper}}_S3_ENDPOINT="localhost:9000"
export {{cookiecutter.package_name_upper}}_S3_BUCKET="lake-data"
export {{cookiecutter.package_name_upper}}_S3_ACCESS_KEY="minioadmin"
export {{cookiecutter.package_name_upper}}_S3_SECRET_KEY="minioadmin"
export {{cookiecutter.package_name_upper}}_APP_DB_DSN="host=localhost port=5432 dbname={{cookiecutter.project_slug}}_app user=postgres password=postgres"

# --- Optional ---
export {{cookiecutter.package_name_upper}}_HOST="0.0.0.0"
export {{cookiecutter.package_name_upper}}_PORT="8000"
export {{cookiecutter.package_name_upper}}_DEV_MODE="true"

# DuckLake catalog (PostgreSQL recommended for production)
export {{cookiecutter.package_name_upper}}_CATALOG_DSN="host=localhost port=5432 dbname={{cookiecutter.project_slug}}_lake user=postgres password=postgres"

# DuckDB resource limits
export {{cookiecutter.package_name_upper}}_DUCKDB_MEMORY_LIMIT="4GB"
export {{cookiecutter.package_name_upper}}_DUCKDB_THREADS="4"

# Encryption (auto-generated per-file keys stored in catalog)
export {{cookiecutter.package_name_upper}}_ENCRYPTION_ENABLED="false"

# SMTP (for magic link emails)
export {{cookiecutter.package_name_upper}}_SMTP_HOST="localhost"
export {{cookiecutter.package_name_upper}}_SMTP_PORT="587"
# export {{cookiecutter.package_name_upper}}_SMTP_USER=""
# export {{cookiecutter.package_name_upper}}_SMTP_PASS=""
export {{cookiecutter.package_name_upper}}_EMAIL_FROM="noreply@{{cookiecutter.project_slug}}.local"

# Auth timeouts
export {{cookiecutter.package_name_upper}}_MAGIC_LINK_EXPIRY="900"
export {{cookiecutter.package_name_upper}}_SESSION_EXPIRY="604800"

# Docker
export DOCKER_REGISTRY="{{cookiecutter.docker_registry}}"
